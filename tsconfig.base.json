{
  "compilerOptions": {
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "downlevelIteration": true,
    "baseUrl": ".",
    "paths": {
      "@novx/core": ["libs/core/src/index.ts"],
      "@novx/i18n": ["libs/i18n/src/index.ts"],
      "@novx/communication": ["libs/communication/src/index.ts"],
      "@novx/portal": ["libs/portal/src/index.ts"]
    },
    "sourceMap": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022", "dom"],
    "module": "esnext",
    "moduleResolution": "node",
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "target": "es2022"
  }
}