{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "app",
  "root": "apps/app",
  "sourceRoot": "apps/app/src",
  "projectType": "application",
  "targets": {
    "scan-metadata": {
      "executor": "nx:run-commands",
      "options": {
        "command": "nx run metadata:scan --moduleFolder=apps/app --outFile=apps/app/src/manifest.json"
      }
    },
    "build": {
      "executor": "@nx/webpack:webpack",
      "options": {
        "outputPath": "dist/apps/app",
        "main": "apps/app/src/main.tsx",
        "tsConfig": "apps/app/tsconfig.app.json",
        "index": "apps/app/src/index.html",
        "webpackConfig": "apps/app/webpack.config.js",
        "optimization": false,
        "sourceMap": true
      },
      "configurations": {
        "production": {
          "optimization": true,
          "sourceMap": false,
          "extractLicenses": true,
          "inspect": false
        },
        "development": {
          "optimization": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "development"
    },
    "serve": {
      "executor": "@nx/webpack:dev-server",
      "options": {
        "buildTarget": "app:build:development",
        "host": "localhost",
        "port": 3000
      },
      "configurations": {
        "production": {
          "buildTarget": "app:build:production"
        },
        "development": {
          "buildTarget": "app:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["apps/app/**/*.ts", "apps/app/**/*.tsx"]
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{workspaceRoot}/coverage/apps/app"],
      "options": {
        "configFile": "apps/app/vitest.config.ts"
      }
    }
  },
  "tags": []
}