{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "rootDir": "src",
    "outDir": "../../dist/libs/ui",
    "tsBuildInfoFile": "../../dist/libs/ui/tsconfig.lib.tsbuildinfo",
    "module": "esnext",
    "target": "es2022",
    "moduleResolution": "node"
  },
  "include": ["src/**/*.ts"],
  "references": [
    {"path": "../core"},
    {"path": "../portal"},
    {"path": "../i18n"}
  ],
  "exclude": [
    "jest.config.ts",
    "jest.config.cts",
    "src/**/*.spec.ts",
    "src/**/*.test.ts"
  ]
}
