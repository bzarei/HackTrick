{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "communication",
  "root": "libs/communication",
  "sourceRoot": "libs/communication/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/js:swc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/communication",
        "tsConfig": "libs/communication/tsconfig.lib.json",
        "packageJson": "libs/communication/package.json",
        "main": "libs/communication/src/index.ts",
        "assets": ["libs/communication/*.md"]
      },
      "dependsOn": ["^build"]
    },
    "build:types": {
      "executor": "@nx/js:tsc",
      "options": {
        "tsConfig": "libs/communication/tsconfig.lib.json",
        "emitDeclarationOnly": true,
        "outDir": "dist/libs/communication"
      },
      "dependsOn": ["^build:types"]
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/libs/communication"],
      "options": {
        "jestConfig": "libs/communication/jest.config.cts",
        "passWithNoTests": true
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["libs/communication/**/*.ts"]
      }
    },
    "docs": {
      "executor": "nx:run-commands",
      "options": {
        "command": "typedoc --tsconfig libs/communication/tsconfig.lib.json --out docs/libs/communication"
      }
    }
  }
}