{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "rootDir": "src",
    "outDir": "../../dist/libs/communication",
    "tsBuildInfoFile": "../../dist/libs/communication/tsconfig.lib.tsbuildinfo",
    "module": "esnext",
    "target": "es2022",
    "moduleResolution": "node"
  },
  "include": ["src/**/*.ts"],
  "references": [
    {"path": "../core"}
  ],
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.test.ts"
  ]
}
