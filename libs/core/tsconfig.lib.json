{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "esModuleInterop": true,
    "declaration": true,
    "declarationMap": true,
    "rootDir": "src",
    "outDir": "../../dist/libs/core",
    "tsBuildInfoFile": "../../dist/libs/core/tsconfig.lib.tsbuildinfo",
    "module": "esnext",
    "target": "es2022",
    "moduleResolution": "node",
    "strict": true,
    "types": ["node"],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.test.ts"
  ],
  "references": []
}