{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "core",
  "root": "libs/core",
  "sourceRoot": "libs/core/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/rollup:rollup",
      "options": {
        "outputPath": "dist/libs/core",
        "tsConfig": "libs/core/tsconfig.lib.json",
        "project": "libs/core/rollup.config.json",
        "main": "libs/core/src/index.ts"
      }
    },
    "build:types": {
      "executor": "@nx/js:tsc",
      "options": {
        "tsConfig": "libs/core/tsconfig.lib.json",
        "emitDeclarationOnly": true,
        "outDir": "dist/libs/core",
        "outputPath": "dist/libs/core",
        "main": "dist/libs/core/index.js"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/libs/core"],
      "options": {
        "jestConfig": "libs/core/jest.config.cts",
        "passWithNoTests": true
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["libs/core/**/*.ts"]
      }
    },
    "docs": {
      "executor": "nx:run-commands",
      "options": {
        "command": "typedoc --tsconfig libs/core/tsconfig.lib.json --out docs/libs/core"
      }
    }
  }
}