{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "composite": true,
    "declaration": true,
    "rootDir": "src",
    "outDir": "../../dist/libs/portal",
    "tsBuildInfoFile": "../../dist/libs/portal/tsconfig.lib.tsbuildinfo",
    "types": ["dom", "webpack-env"],
    "module": "esnext",
    "target": "es2022",
    "moduleResolution": "node"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "references": [
    {"path": "../core"},
    {"path": "../communication"},
    {"path": "../i18n"}
  ],
  "exclude": [
    "jest.config.ts",
    "jest.config.cts",
    "src/**/*.spec.ts",
    "src/**/*.test.ts"
  ]
}
