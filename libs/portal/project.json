{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "portal",
  "root": "libs/portal",
  "sourceRoot": "libs/portal/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/rollup:rollup",
      "options": {
        "outputPath": "dist/libs/portal",
        "tsConfig": "libs/portal/tsconfig.lib.json",
        "project": "libs/portal/rollup.config.json",
        "main": "libs/portal/src/index.ts",
        "external": ["@novx/core", "@novx/i18n", "@novx/communication"],
        "sourceMap": true,
        "assets": [
          {
            "input": "libs/portal",
            "glob": "package.json",
            "output": "."
          },
          {
            "input": "libs/portal",
            "glob": "README.md",
            "output": "."
          }
        ]
      },
      "dependsOn": ["^build"]
    },
    "build:types": {
      "executor": "@nx/js:tsc",
      "dependsOn": ["^build"],
      "options": {
        "tsConfig": "libs/portal/tsconfig.lib.json",
        "outDir": "dist/libs/portal",
        "outputPath": "dist/libs/portal",
        "main": "dist/libs/portal/index.js"
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{workspaceRoot}/coverage/libs/portal"],
      "options": {
        "configFile": "libs/portal/vitest.config.ts"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["libs/portal/src/**/*.{ts,tsx,js,jsx}"]
      }
    },
    "docs": {
      "executor": "nx:run-commands",
      "options": {
        "command": "typedoc --tsconfig libs/portal/tsconfig.lib.json --out docs/libs/portal"
      }
    }
  }
}