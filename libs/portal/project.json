{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "portal",
  "root": "libs/portal",
  "sourceRoot": "libs/portal/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nx/rollup:rollup",
      "options": {
        "outputPath": "dist/libs/portal",
        "tsConfig": "libs/portal/tsconfig.lib.json",
        "project": "libs/portal/rollup.config.json",
        "main": "libs/portal/src/index.ts"
      },
      "dependsOn": ["^build"]
    },
    "build:types": {
      "executor": "@nx/js:tsc",
      "dependsOn": ["^build"],
      "options": {
        "tsConfig": "libs/portal/tsconfig.lib.json",
        "outDir": "dist/libs/portal",
        "outputPath": "dist/libs/portal",
        "main": "dist/libs/portal/index.js"
      },
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/libs/portal"],
      "options": {
        "jestConfig": "libs/portal/jest.config.cts",
        "passWithNoTests": true
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["libs/portal/**/*.ts", "libs/portal/**/*.tsx"]
      }
    },
    "docs": {
      "executor": "nx:run-commands",
      "options": {
        "command": "typedoc --tsconfig libs/portal/tsconfig.lib.json --out docs/libs/portal"
      }
    }
  }
}