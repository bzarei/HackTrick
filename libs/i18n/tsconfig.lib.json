{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "rootDir": "src",
    "outDir": "dist/libs/i18n",
    "tsBuildInfoFile": "dist//libs/i18n/tsconfig.lib.tsbuildinfo",
  },
  "include": ["src/**/*.ts"],
  "references": [
    {"path": "../core"}
  ],
  "exclude": [
    "jest.config.ts",
    "jest.config.cts",
    "src/**/*.spec.ts",
    "src/**/*.test.ts"
  ]
}
