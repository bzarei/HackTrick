{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "rootDir": "src",
    "outDir": "../../dist/libs/i18n",
    "tsBuildInfoFile": "../../dist/libs/i18n/tsconfig.lib.tsbuildinfo",
    "module": "esnext",
    "moduleResolution": "node",
    "strict": true,
    "target": "es2022"
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.test.ts"
  ],
  "references": [
    { "path": "../core" },
    { "path": "../portal" }
  ]
}